{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  // opencode-isolate: エージェントの作業を git worktree に隔離するプラグイン。
  // 破壊的変更を無警告で取り込まないよう、バージョンを固定する。
  "plugin": ["opencode-isolate@0.1.0"],
  "permission": {
    "edit": "allow",
    "read": "allow",
    "bash": "ask",
    "websearch": "ask"
  },
  "compaction": {
    "prune": false
  }
}